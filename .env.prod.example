# Production environment for the docker-compose stack.
#   cp .env.prod.example .env.prod   &&   edit the secrets below
#   docker compose --env-file .env.prod up -d --build
#
# This single file is used two ways:
#   1. `--env-file .env.prod` feeds compose ${...} interpolation (POSTGRES_*, HTTP_PORT, DATABASE_URL).
#   2. `env_file: .env.prod` injects the app config into the server/worker containers.

# ── Postgres service (must match DATABASE_URL below) ──────────────────────────
POSTGRES_USER=cmstack
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=cmstack

# ── App runtime ───────────────────────────────────────────────────────────────
APP_ENV=production
# Host port the server is published on (container always listens on :8090).
HTTP_PORT=8090
HTTP_ADDR=:8090
# Externally reachable base URL (used for absolute links, canonical, OG, feeds).
BASE_URL=https://cms.example.com

# DB + cache point at the compose service names on the internal network.
DATABASE_URL=postgres://cmstack:change-me-postgres-password@postgres:5432/cmstack?sslmode=disable
REDIS_URL=redis://redis:6379
CACHE_DRIVER=redis

# Seed administrator (created on first migrate/boot if absent).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Blob storage: local (default) writes to /app/uploads (the `uploads` volume).
# Switch to s3 for object storage and fill the S3_* keys instead.
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# ── Email (M14) ───────────────────────────────────────────────────────────────
# log = write emails to the log (default); smtp = real delivery.
MAIL_DRIVER=log
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# MAIL_FROM=no-reply@example.com
# MAIL_FROM_NAME=CMStack
# SMTP_TLS=starttls

# ── Optional integrations ─────────────────────────────────────────────────────
# reCAPTCHA v3 (public forms are enforced only when both keys are set).
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET=
# Social login (OAuth) — configure per provider as needed. OAUTH_CALLBACK_BASE
# defaults to BASE_URL when empty.
# OAUTH_CALLBACK_BASE=
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# Contact-form recipient (falls back to ADMIN_EMAIL when empty).
# CONTACT_RECIPIENT=
# Enforce email verification before login (default off).
# EMAIL_VERIFICATION_REQUIRED=false
