# CMStack-Go environment. Copy to .env and adjust. Read by internal/platform/config.

# Environment: development | production | test. Controls log level and HSTS.
APP_ENV=development

# HTTP listen address. Default :8090 keeps the Go stack clear of the sibling
# cmstack-* projects during local dev (see ../PORTS.md for the full allocation).
HTTP_ADDR=:8090

# Externally reachable base URL (absolute links, redirects).
BASE_URL=http://localhost:8090

# Postgres DSN (REQUIRED). Port 5434 is this stack's slot so its Postgres does
# not collide with cmstack-ts (5432) / cmstack-django (5433) — see ../PORTS.md.
DATABASE_URL=postgres://postgres:postgres@localhost:5434/cmstack?sslmode=disable

# Redis URL (optional; caching/sessions when present).
REDIS_URL=

# RESERVED (not yet required). The future Postgres-backed session store / cookie
# signing will consume this; the current scs in-memory store ignores it, so a
# required-but-ignored secret would be misleading. Set a long random value once
# the persistent session store lands (TODO M1).
SESSION_KEY=

# Timeouts (Go duration strings).
SHUTDOWN_TIMEOUT=15s
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s

# --- Auth (M1) ---------------------------------------------------------------

# Public registration toggle. Read by the auth SettingsProvider (admin-UI source
# arrives in M15).
SIGNUP_ENABLED=true

# Enforce a verified email before login.
EMAIL_VERIFICATION_REQUIRED=false

# Default administrator, created idempotently by the startup seed. The password
# default below is for LOCAL DEVELOPMENT ONLY — set a strong value in production.
ADMIN_EMAIL=admin@cmstack.local
ADMIN_PASSWORD=changeme-admin-password

# --- Uploads / Media storage (M1-ext + M4) -----------------------------------
# Filesystem root for user uploads when STORAGE_DRIVER=local (avatars + media).
# Served read-only at /uploads with X-Content-Type-Options: nosniff.
UPLOAD_DIR=./uploads

# Storage driver: local | s3. "local" writes under UPLOAD_DIR and serves
# /uploads; "s3" stores objects in an S3 (or S3-compatible) bucket via the S3_*
# vars below. Local is the default and the tested-by-default backend.
STORAGE_DRIVER=local

# Max bytes for a single media upload (default 10 MiB). Enforced on bytes
# actually read, not a client-declared Content-Length.
MEDIA_MAX_BYTES=10485760

# S3 / S3-compatible object storage (used only when STORAGE_DRIVER=s3).
# Bucket + region are required for AWS. For MinIO / Cloudflare R2 / other
# S3-compatible providers, set S3_ENDPOINT and usually S3_USE_PATH_STYLE=true.
# Credentials may be left blank to use the AWS default credential chain
# (env / shared config / IAM role). S3_PUBLIC_BASE_URL is an optional CDN /
# website base used to build object URLs (else derived from endpoint/bucket).
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_USE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=

# --- Content / Posts (M2a) ----------------------------------------------------
# No additional configuration is required. The worker process runs a periodic
# scheduled-publishing scan (PostService.PublishDue) on a fixed 30s interval,
# reusing DATABASE_URL + BASE_URL. River (durable jobs) is the documented upgrade
# path if at-least-once scheduling durability across crashes is needed.

# --- OAuth (M1-ext placeholders; table exists, wiring deferred) ---------------
# Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# GitHub
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# --- Comments (M5) ------------------------------------------------------------
# reCAPTCHA v3 anti-spam for GUEST comment submissions. OPTIONAL: leave empty to
# run without keys (the verifier becomes a graceful no-op and guest comments
# work). When the secret is set, a guest submission must carry a token whose
# score meets RECAPTCHA_MIN_SCORE. The site key is rendered into the public form.
RECAPTCHA_SECRET=
RECAPTCHA_SITE_KEY=
RECAPTCHA_MIN_SCORE=0.5
# Per-IP comment submission rate limit (submissions/minute). Default 8/min.
COMMENT_RATE_LIMIT_PER_MINUTE=8
# Signed-in authors may edit/delete their own comment within this window
# (minutes). The current default mirrors the reference stacks (15 min) and is set
# in code; this var is reserved for a future override.
# COMMENT_EDIT_WINDOW_MINUTES=15

# --- Analytics: GA4 + GTM (M15-1) --------------------------------------------
# Public-pages-only Google Analytics 4 (gtag.js) and/or Google Tag Manager.
# There is NO env var for this: the container ids are configured in
# Admin -> Settings and stored in the settings table under the keys
# `analytics_ga4_id` (e.g. G-ABC1234) and `analytics_gtm_id` (e.g. GTM-ABCD12).
# Both default to empty = analytics disabled. Admin pages never emit analytics.
