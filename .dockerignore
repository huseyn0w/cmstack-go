# Build artifacts and local-only files that must never enter the image context.
.git
.github
bin/                    # downloaded tailwind CLI (re-fetched in the build stage)
web/static/app.css      # generated by tailwind in the build stage
uploads/                # runtime blob storage (a volume in prod)
coverage.out
*.out
*.test
*.exe
.env
.env.*
!.env.prod.example
# Stray cmd binaries occasionally built at the repo root
/apitoken
/mcp
/server
/worker
/migrate
/seed
/seedcontent
# Editor / OS noise
.DS_Store
.claude/settings.local.json
